<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">

      <div class="card shadow">
        <div class="card-header bg-primary text-white text-center">
          <h2 class="mb-0">Edit Hospital</h2>
        </div>

        <div class="card-body">
          <%= form_with model: @hospital do |form| %>

            <div class="mb-3">
              <%= form.label :name, class: "form-label" %>
              <%= form.text_field :name, class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= form.label :address_line1, class: "form-label" %>
              <%= form.text_field :address_line1, class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= form.label :address_line2, class: "form-label" %>
              <%= form.text_field :address_line2, class: "form-control" %>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <%= form.label :city, class: "form-label" %>
                <%= form.text_field :city, class: "form-control" %>
              </div>

              <div class="col-md-6 mb-3">
                <%= form.label :state, class: "form-label" %>
                <%= form.text_field :state, class: "form-control" %>
              </div>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <%= form.label :zipcode, class: "form-label" %>
                <%= form.text_field :zipcode, class: "form-control" %>
              </div>

              <div class="col-md-6 mb-3">
                <%= form.label :country, class: "form-label" %>
                <%= form.text_field :country, class: "form-control" %>
              </div>
            </div>

            <div class="mb-3">
              <%= form.label :phone_number, class: "form-label" %>
              <%= form.telephone_field :phone_number, class: "form-control" %>
            </div>

            <div class="mb-4">
              <%= form.label :date_of_establishment, "Date of Establishment", class: "form-label" %>
              <%= form.date_field :date_of_establishment, class: "form-control" %>
            </div>

            <div class="mb-4">
              <%= form.label :reason, "Reason For Updating Details", class: "form-label" %>
              <%= text_area_tag :reason, nil, rows: 4, class: "form-control" %>
            </div>

            <div class="d-grid">
              <%= form.submit "Update Hospital", class: "btn btn-primary btn-lg" %>
            </div>

          <% end %>
        </div>

        <div class="card-footer text-center">
          <%= link_to "Back to Hospitals", hospitals_path, class: "btn btn-outline-secondary" %>
        </div>

      </div>

    </div>
  </div>
</div>