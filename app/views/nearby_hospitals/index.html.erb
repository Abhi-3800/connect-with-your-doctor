<div class="container mt-4">
  <h2 class="text-center mb-4">
    Search Hospitals Near You
  </h2>

  <%= form_with url: search_nearby_hospitals_path, method: :get, local: true, data: { turbo: false }, class: "row justify-content-center" do |f| %>
    <div class="col-md-6">
      <%= f.text_field :location, value: params[:location], class: "form-control", placeholder: "Enter city or region" %>
    </div>
    <div class="col-md-4 d-flex gap-2">
      <%= f.submit "Search", class: "btn btn-primary w-100" %>
      <%= link_to 'Back to Hospitals', hospitals_path, class: 'btn btn-secondary w-100' %>
    </div>
  <% end %>
</div>